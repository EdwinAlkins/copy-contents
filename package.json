{
  "name": "copy-contents",
  "displayName": "copy-contents",
  "description": "Copy all file in presse papier",
  "version": "0.0.2",
  "publisher": "edwinalkins",
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-contents.copy",
        "title": "Copy Folder Contents"
      },
      {
        "command": "copy-contents.copyWithSelection",
        "title": "Copy with Selection"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "copy-contents.copy",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace"
        },
        {
          "command": "copy-contents.copyWithSelection",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace"
        }
      ]
    },
    "capabilities": {
      "untrustedWorkspaces": {
        "supported": true
      }
    },
    "configuration": {
      "title": "Copy Folder Contents",
      "properties": {
        "copyContents.extensions": {
          "type": "array",
          "default": [
            ".ts",
            ".js",
            ".json",
            ".md",
            ".py",
            ".yaml"
          ],
          "items": {
            "type": "string"
          },
          "description": "The list of extensions to copy"
        },
        "copyContents.excludedFolders": {
          "type": "array",
          "default": [
            ".git",
            ".vscode",
            ".DS_Store",
            ".idea",
            ".pytest_cache",
            ".venv",
            "venv"
          ],
          "items": {
            "type": "string"
          },
          "description": "The list of folders to exclude"
        },
        "copyContents.maxFiles": {
          "type": "number",
          "default": 100,
          "description": "The maximum number of files to copy"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.105.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "sinon": "^22.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
