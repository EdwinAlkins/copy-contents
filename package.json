{
  "name": "copy-contents",
  "icon": "icon.png",
  "displayName": "Copy Contents",
  "description": "Copy all files to clipboard",
  "version": "0.0.4",
  "publisher": "edwinalkins",
  "repository": {
    "type": "git",
    "url": "https://github.com/edwinalkins/copy-contents"
  },
  "keywords": ["clipboard", "copy", "folder", "files", "content"],
  "engines": {
    "vscode": "^1.105.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:copy-contents.copy",
    "onCommand:copy-contents.copyWithSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-contents.copy",
        "title": "Copy Folder Contents"
      },
      {
        "command": "copy-contents.copyWithSelection",
        "title": "Copy with Selection"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "copy-contents.copy",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace"
        },
        {
          "command": "copy-contents.copyWithSelection",
          "when": "explorerResourceIsFolder",
          "group": "2_workspace"
        }
      ]
    },
    "capabilities": {
      "untrustedWorkspaces": {
        "supported": true
      }
    },
    "configuration": {
      "title": "Copy Folder Contents",
      "properties": {
        "copyContents.extensions": {
          "type": "array",
          "default": [
            ".ts",
            ".tsx",
            ".js",
            ".jsx",
            ".json",
            ".md",
            ".py",
            ".yaml",
            ".rs",
            ".toml"
          ],
          "items": {
            "type": "string"
          },
          "description": "The list of file extensions to copy"
        },
        "copyContents.excludedFolders": {
          "type": "array",
          "default": [
            ".git",
            ".vscode",
            ".DS_Store",
            ".idea",
            ".pytest_cache",
            ".venv",
            "venv",
            "node_modules",
            "__MACOSX",
            "Thumbs.db",
            "dist",
            "build",
            "target",
            "__pycache__",
            ".pytest_cache"
          ],
          "items": {
            "type": "string"
          },
          "description": "The list of folders to exclude from copying"
        },
        "copyContents.maxFiles": {
          "type": "number",
          "default": 100,
          "description": "The maximum number of files to copy"
        },
        "copyContents.maxFileSize": {
          "type": "number",
          "default": 1048576,
          "description": "The maximum file size in bytes to copy (default: 1MB)"
        },
        "copyContents.copyWithoutHeaders": {
          "type": "boolean",
          "default": false,
          "description": "Copy file contents without file name headers"
        },
        "copyContents.headerFormat": {
          "type": "string",
          "default": "--- File: {path} ---",
          "description": "Template for the header placed before each file. Use {path} as a placeholder for the file path (e.g. \"# {path}\" or \"=== {path} ===\")"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.105.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "sinon": "^22.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
